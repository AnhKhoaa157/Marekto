# Copy this file to .env for local development.
# Keep all real credentials in .env only; never commit secrets.
#
# In production, the server-only preflight in src/lib/env-preflight.ts validates
# these values and fails closed on insecure or missing production settings.

# ──────────────────────────────────────────────────────────────────────────
# Runtime
# ──────────────────────────────────────────────────────────────────────────
# "development" or "production". Production enables strict secret/SSL checks.
NODE_ENV=
# Local port used by the application.
PORT=

# ──────────────────────────────────────────────────────────────────────────
# Database (PostgreSQL)
# ──────────────────────────────────────────────────────────────────────────
# Full PostgreSQL connection URL. Do not commit URLs containing credentials.
# The application connects via DATABASE_URL only.
DATABASE_URL=
# TLS intent. Accepts: disable | require | verify-ca | verify-full (or a
# boolean-like value). For a REMOTE production database this must NOT be
# disabled — the preflight rejects a remote prod database with TLS off.
# Leave blank to use the safe default (TLS on in production for remote hosts).
DATABASE_SSL=
# Optional individual connection fields for local database tools (DBeaver, psql).
# The application itself does not use these; DATABASE_URL is authoritative.
DB_USER=
DB_HOST=
DB_NAME=
DB_PASSWORD=
DB_PORT=

# ──────────────────────────────────────────────────────────────────────────
# Authentication
# ──────────────────────────────────────────────────────────────────────────
# JWT signing secret. Use a long, cryptographically random value.
# Production requires >= 32 characters and rejects known-default values.
#   Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=
# Redis is required for single-session enforcement and auth rate limits.
REDIS_URL=redis://localhost:6379

# ──────────────────────────────────────────────────────────────────────────
# Cron worker
# ──────────────────────────────────────────────────────────────────────────
# Shared bearer secret required to trigger POST/GET /api/worker/cron.
# In production this is REQUIRED (the worker fails closed without it) and must
# be >= 16 characters. In development, an unset secret leaves the route open.
CRON_SECRET=

# ──────────────────────────────────────────────────────────────────────────
# Gemini AI
# ──────────────────────────────────────────────────────────────────────────
# Primary provider key. If unset, AI segmentation/builder/personalization fall
# back to safe non-AI behavior instead of failing.
GEMINI_API_KEY=
# Optional comma/semicolon/newline-separated fallback provider keys, tried on
# 401/403/429 from the primary key.
GEMINI_FALLBACK_API_KEYS=
# Provider request timeout in milliseconds. Integer between 1000 and 120000.
GEMINI_TIMEOUT_MS=

# ──────────────────────────────────────────────────────────────────────────
# Data intelligence service (internal Python FastAPI)
# ──────────────────────────────────────────────────────────────────────────
# Base URL of the internal data-intelligence service. Server-side only; never
# exposed to the browser. If unset, data-intelligence features fail safely
# instead of breaking core flows.
DATA_INTELLIGENCE_BASE_URL=
# Shared HMAC-SHA256 signing secret for internal requests. Must match the
# DATA_INTELLIGENCE_INTERNAL_SECRET configured on the Python service.
DATA_INTELLIGENCE_INTERNAL_SECRET=
# Request timeout in milliseconds. Integer between 1000 and 120000.
DATA_INTELLIGENCE_TIMEOUT_MS=

# Billing provider. Use "mock" for local smoke tests, or "sepay" with
# SEPAY_SANDBOX=true to test the VietQR/webhook flow without real money.
BILLING_PROVIDER=mock
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Mock webhook signature used by POST /api/billing/webhook in local testing.
BILLING_MOCK_WEBHOOK_SECRET=marekto-mock-billing-secret
# Future provider secrets/placeholders.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_TEAM_PRICE_ID=
# SePay sandbox accepts unsigned local webhooks when SEPAY_SANDBOX=true. In
# production, set SEPAY_WEBHOOK_SECRET and configure SePay API Key auth with:
# Authorization: Apikey <SEPAY_WEBHOOK_SECRET>
SEPAY_SANDBOX=true
SEPAY_WEBHOOK_SECRET=

# ──────────────────────────────────────────────────────────────────────────
# SMTP email delivery
# ──────────────────────────────────────────────────────────────────────────
# All five fields are required together for delivery to work. If unset,
# campaign delivery is disabled (recipient logs are marked failed).
# Optional fixed registration OTP for local development only. Ignored in production.
REGISTRATION_DEV_OTP=
# Optional fixed forgot-password OTP for local development only.
PASSWORD_RESET_DEV_OTP=
SMTP_HOST=
# Integer between 1 and 65535 (commonly 587 for STARTTLS, 465 for implicit TLS).
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
# Sender address used for outgoing email.
SMTP_FROM=
# "true" for an implicit-TLS port (e.g. 465); "false" otherwise.
SMTP_SECURE=
