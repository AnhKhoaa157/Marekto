# Copy this file to .env for local development.
# Keep all real credentials in .env only; never commit secrets.

# Application
# Local port used by the application.
PORT=

# PostgreSQL
# Full PostgreSQL connection URL. Do not commit URLs containing credentials.
DATABASE_URL=
# Individual connection fields for local database tools or environments that use them.
DB_USER=
DB_HOST=
DB_NAME=
DB_PASSWORD=
DB_PORT=

# Authentication
# Use a long, cryptographically random signing secret.
JWT_SECRET=

# SMTP email delivery
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
# Sender address used for outgoing email.
SMTP_FROM=
# Set to true when the SMTP provider requires a secure connection.
SMTP_SECURE=

# Gemini AI
# Primary provider key.
GEMINI_API_KEY=
# Optional comma-separated fallback provider keys.
GEMINI_FALLBACK_API_KEYS=
# Provider request timeout in milliseconds.
GEMINI_TIMEOUT_MS=
