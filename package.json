{
  "name": "marekto",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --test --experimental-strip-types tests/*.test.mjs",
    "test:integration": "node scripts/run-integration-tests.mjs",
    "smoke:e2e": "node scripts/run-e2e-smoke.mjs",
    "smoke:live": "node scripts/run-e2e-smoke.mjs --live",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm run lint && npm test && npm run build",
    "postman:check": "node scripts/validate-postman.mjs",
    "db:migrate": "docker compose run --rm flyway migrate",
    "db:info": "docker compose run --rm flyway info",
    "db:validate": "docker compose run --rm flyway validate"
  },
  "engines": {
    "node": ">=22.6.0"
  },
  "dependencies": {
    "@types/swagger-ui-react": "^5.18.0",
    "dotenv": "^17.4.2",
    "jose": "^6.2.3",
    "next": "16.2.9",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.11",
    "pg": "^8.21.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "redis": "^5.12.1",
    "swagger-ui-react": "^5.32.6",
    "three": "^0.180.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.180.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
