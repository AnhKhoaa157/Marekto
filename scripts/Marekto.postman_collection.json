          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"contact.postman@example.com\",\n  \"first_name\": \"An\",\n  \"last_name\": \"Nguyen\",\n  \"phone\": \"+84000000001\",\n  \"properties\": {\"city\": \"HCM\", \"lead_score\": 92, \"tags\": [\"VIP\"]}\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/api/contacts"
          }
