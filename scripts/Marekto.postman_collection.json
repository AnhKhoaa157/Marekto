            "description": "Destructive request."
          }
        },
        {
          "name": "List contacts in list",
          "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/api/lists/{{listId}}/contacts" }
        },
        {
          "name": "Add contact to list",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"contact_id\": {{contactId}}\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/api/lists/{{listId}}/contacts"
          }
        },
        {
          "name": "Remove contact from list",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/api/lists/{{listId}}/contacts?contact_id={{contactId}}"
          }
        }
      ]
    },
    {
      "name": "Templates",
