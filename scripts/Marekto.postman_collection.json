{
  "info": {
    "_postman_id": "4c54bb3e-5e55-4b75-a73b-bb47d17d7c37",
    "name": "Marekto Backend API",
    "description": "Canonical backend contract. Review and update this collection after every backend logic change, then run npm run postman:check. Never store real credentials or production tenant data here.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{authToken}}", "type": "string" }]
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test(\"Response is JSON\", function () {",
          "  pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");",
          "});",
          "if (!pm.request.url.getPath().endsWith(\"/api/openapi.json\")) {",
          "  pm.test(\"Response uses the success envelope\", function () {",
          "    const payload = pm.response.json();",
          "    pm.expect(payload.success).to.be.a(\"boolean\");",
          "    if (payload.success) pm.expect(payload).to.have.property(\"data\");",
          "    else pm.expect(payload.error).to.be.a(\"string\");",
          "  });",
          "}",
          ""
        ]
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "authToken", "value": "" },
    { "key": "cronSecret", "value": "" },
    { "key": "registrationEmail", "value": "postman@example.com" },
    { "key": "registrationPassword", "value": "ChangeMe123!" },
    { "key": "registrationOtp", "value": "" },
    { "key": "workspaceName", "value": "Postman Workspace" },
    { "key": "userId", "value": "" },
    { "key": "workspaceId", "value": "" },
    { "key": "contactId", "value": "1" },
    { "key": "listId", "value": "1" },
    { "key": "templateId", "value": "1" },
    { "key": "campaignId", "value": "1" },
    { "key": "emailLogLimit", "value": "50" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Start registration",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{registrationEmail}}\",\n  \"password\": \"{{registrationPassword}}\",\n  \"workspaceName\": \"{{workspaceName}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/api/auth/register",
            "description": "Sends a real OTP. Expected success status: 202."
          }
        },
        {
          "name": "Verify registration OTP",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "if (pm.response.code === 201) {",
                "  const data = pm.response.json().data;",
                "  pm.collectionVariables.set(\"authToken\", data.token);",
                "  pm.collectionVariables.set(\"userId\", String(data.userId));",
                "  pm.collectionVariables.set(\"workspaceId\", String(data.workspaceId));",
                "}"
              ]
            }
          }],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{registrationEmail}}\",\n  \"otp\": \"{{registrationOtp}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/api/auth/register/verify"
          }
        },
        {
          "name": "Login",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "if (pm.response.code === 200) {",
                "  const data = pm.response.json().data;",
                "  pm.collectionVariables.set(\"authToken\", data.token);",
                "  pm.collectionVariables.set(\"userId\", String(data.userId));",
                "  pm.collectionVariables.set(\"workspaceId\", String(data.workspaceId));",
                "}"
              ]
            }
          }],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{registrationEmail}}\",\n  \"password\": \"{{registrationPassword}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Logout",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Profile",
      "item": [
        {
          "name": "Get profile",
          "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/api/profile" }
