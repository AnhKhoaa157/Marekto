# Local Docker defaults. Copy this file only if you want to customize values.
# Do not put real production secrets here.

NODE_ENV=development
PORT=3000

DATABASE_URL=postgresql://postgres:postgres@postgres:5432/marekto
DATABASE_SSL=disable

JWT_SECRET=marekto-docker-local-jwt-secret-32-chars-minimum
REDIS_URL=redis://redis:6379
CRON_SECRET=marekto-docker-local-cron-secret

GEMINI_API_KEY=
GEMINI_FALLBACK_API_KEYS=
GEMINI_TIMEOUT_MS=20000

# Fixed local-only registration OTP. Production always uses SMTP delivery.
REGISTRATION_DEV_OTP=123456
PASSWORD_RESET_DEV_OTP=123456
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

DATA_INTELLIGENCE_BASE_URL=http://data-intelligence:8080
DATA_INTELLIGENCE_INTERNAL_SECRET=marekto-docker-local-data-intelligence-secret
DATA_INTELLIGENCE_TIMEOUT_MS=10000
DATA_INTELLIGENCE_MAX_REQUEST_ROWS=1000
DATA_INTELLIGENCE_REQUEST_SKEW_SECONDS=300

BILLING_PROVIDER=mock
NEXT_PUBLIC_APP_URL=http://localhost:3000
BILLING_MOCK_WEBHOOK_SECRET=marekto-mock-billing-secret
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_TEAM_PRICE_ID=
SEPAY_SANDBOX=true
SEPAY_WEBHOOK_SECRET=
